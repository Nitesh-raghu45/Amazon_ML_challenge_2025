# Amazon ML 2025 — .gitignore

# Environment & secrets
.env
.env.local
*.key

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
*.egg

