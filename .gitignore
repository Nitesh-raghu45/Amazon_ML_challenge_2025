.ipynb_checkpoints/
*.ipynb

# Dataset & large files (do not commit)
archive/train.csv
archive/test.csv
archive/sample_test.csv
archive/embedding/
archive/extraction/
Images/

# Model outputs
outputs/*.pkl
outputs/*.csv

# Logs
*.log
cufile.log

# OS
.DS_Store
Thumbs.db
